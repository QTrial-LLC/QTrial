# OffLeash local development environment.
#
# Copy to `.env` (gitignored) and uncomment what you need. Docker
# Compose auto-loads `.env`; scripts/smoke-compose.sh sources the same
# file so both stay in sync.
#
# Defaults match the canonical ports for each service. If another local
# stack is already bound to those ports, switch to the alt scheme
# below.

# ----- Canonical ports (defaults, no need to set unless overriding) -----
# OFFLEASH_POSTGRES_PORT=5432
# OFFLEASH_KEYCLOAK_PORT=8080
# OFFLEASH_NATS_CLIENT_PORT=4222
# OFFLEASH_NATS_HTTP_PORT=8222
# OFFLEASH_VALKEY_PORT=6379

# ----- Alt ports (coexistence with another stack on the same host) -----
# OFFLEASH_POSTGRES_PORT=15432
# OFFLEASH_KEYCLOAK_PORT=18080
# OFFLEASH_NATS_CLIENT_PORT=14222
# OFFLEASH_NATS_HTTP_PORT=18222
# OFFLEASH_VALKEY_PORT=16379
